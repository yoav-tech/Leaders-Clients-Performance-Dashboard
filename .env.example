# --- Database (Supabase) ---
# The app + ingestion use the Supabase HTTP Data API (works on Vercel; no pooler/IPv6).
# From Supabase → Project Settings → API:
SUPABASE_URL="https://<ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ...service_role secret..."

# Only the local `npm run db:setup` (DDL) uses a direct connection. Optional otherwise.
DATABASE_URL="postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres"

# --- Windsor.ai ---
# Find your key at https://windsor.ai (Account → API key).
WINDSOR_API_KEY=""

# --- Cron / ingestion auth ---
# Any long random string. Vercel Cron sends it as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=""

# --- Dashboard access gate ---
# When DASHBOARD_PASSWORD is set, the whole dashboard requires HTTP Basic Auth.
# Leave empty to disable the gate (e.g. local dev). DASHBOARD_USER is optional.
DASHBOARD_USER="leaders"
DASHBOARD_PASSWORD=""

# --- FX (optional) ---
# Defaults to a free exchangerate.host endpoint; override to use a keyed provider.
# FX_API_URL="https://api.exchangerate.host/latest?base=USD&symbols=ILS"

# --- QuickShop (store/site revenue) ---
# One key per QuickShop store, named QUICKSHOP_API_KEY_<BRAND_ID_UPPER>.
# Key format qs_live_...; sent as `X-API-Key`. Base: https://my-quickshop.com/api/v1
QUICKSHOP_API_KEY_ARGANIA=""
# QUICKSHOP_API_KEY_STUDIO_PASHA=""
