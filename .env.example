# --- Database (Vercel Postgres / Neon) ---
# Vercel's Neon integration sets these automatically in the deployment.
# For local dev, copy this file to .env.local and paste the pooled connection string.
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# --- Windsor.ai ---
# Find your key at https://windsor.ai (Account → API key).
WINDSOR_API_KEY=""

# --- Cron / ingestion auth ---
# Any long random string. Vercel Cron sends it as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=""

# --- FX (optional) ---
# Defaults to a free exchangerate.host endpoint; override to use a keyed provider.
# FX_API_URL="https://api.exchangerate.host/latest?base=USD&symbols=ILS"

# --- QuickShop (pending) ---
# For Argania & Studio Pasha site revenue once API/export access is available.
# QUICKSHOP_API_KEY=""
